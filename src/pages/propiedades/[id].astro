---
// 1. Importaciones
import { getCollection, render } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

// 2. Esta función le dice a Astro cuántas páginas debe crear (Una por cada propiedad)
export async function getStaticPaths() {
  const propiedades = await getCollection('propiedades');
  return propiedades.map(prop => ({
    params: { id: prop.id },
    props: { propiedad: prop },
  }));
}

// 3. Recibimos la propiedad exacta que el usuario hizo clic
const { propiedad } = Astro.props;

// 4. Procesamos el texto largo (Markdown) para que se vea como HTML
const { Content } = await render(propiedad);
---

<Layout title={propiedad.data.titulo}>
  
  <!-- CABECERA: Imagen Gigante -->
  <div class="relative w-full h-[50vh] min-h-[400px] bg-gray-900">
    <img 
      src={propiedad.data.imagen_destacada} 
      alt={propiedad.data.titulo} 
      class="w-full h-full object-cover opacity-80"
    />
    <div class="absolute inset-0 bg-gradient-to-t from-black/60 to-transparent"></div>
    
    <!-- Etiquetas sobre la foto -->
    <div class="absolute bottom-8 left-4 sm:left-8 lg:left-auto lg:max-w-7xl lg:mx-auto lg:w-full lg:px-8">
      <span class="bg-blue-600 text-white text-sm font-bold px-4 py-2 rounded-lg uppercase tracking-wide mr-2 shadow-lg">
        {propiedad.data.operacion}
      </span>
      <span class="bg-white text-gray-900 text-sm font-bold px-4 py-2 rounded-lg uppercase tracking-wide shadow-lg">
        {propiedad.data.tipo_propiedad}
      </span>
    </div>
  </div>

  <!-- CONTENIDO PRINCIPAL -->
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="flex flex-col lg:flex-row gap-12">
      
      <!-- COLUMNA IZQUIERDA (Detalles 70%) -->
      <div class="lg:w-2/3">
        
        <h1 class="text-4xl font-bold text-gray-900 mb-4 leading-tight">{propiedad.data.titulo}</h1>
        
        <p class="text-lg text-gray-500 mb-8 flex items-center">
          <svg class="w-5 h-5 mr-2 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path></svg>
          {propiedad.data.direccion}
        </p>

        <!-- Barra de características (Iconos) -->
        <div class="flex flex-wrap items-center gap-6 py-6 border-y border-gray-200 mb-8">
          {propiedad.data.dormitorios && (
            <div class="flex flex-col">
              <span class="text-gray-400 text-sm mb-1 uppercase font-semibold">Dormitorios</span>
              <span class="text-xl font-bold text-gray-900 flex items-center gap-2">
                <svg class="w-6 h-6 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"></path></svg>
                {propiedad.data.dormitorios}
              </span>
            </div>
          )}
          {propiedad.data.banos && (
            <div class="flex flex-col">
              <span class="text-gray-400 text-sm mb-1 uppercase font-semibold">Baños</span>
              <span class="text-xl font-bold text-gray-900 flex items-center gap-2">
                <svg class="w-6 h-6 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 15a4 4 0 004 4h9a5 5 0 10-.1-9.999 5.002 5.002 0 10-9.78 2.096A4.001 4.001 0 003 15z"></path></svg>
                {propiedad.data.banos}
              </span>
            </div>
          )}
          {propiedad.data.sup_total && (
            <div class="flex flex-col">
              <span class="text-gray-400 text-sm mb-1 uppercase font-semibold">Sup. Total</span>
              <span class="text-xl font-bold text-gray-900 flex items-center gap-2">
                <svg class="w-6 h-6 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 8V4m0 0h4M4 4l5 5m11-1V4m0 0h-4m4 0l-5 5M4 16v4m0 0h4m-4 0l5-5m11 5l-5-5m5 5v-4m0 4h-4"></path></svg>
                {propiedad.data.sup_total} m²
              </span>
            </div>
          )}
          {propiedad.data.sup_cubierta && (
            <div class="flex flex-col">
              <span class="text-gray-400 text-sm mb-1 uppercase font-semibold">Sup. Cubierta</span>
              <span class="text-xl font-bold text-gray-900 flex items-center gap-2">
                <svg class="w-6 h-6 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"></path></svg>
                {propiedad.data.sup_cubierta} m²
              </span>
            </div>
          )}
        </div>

        <!-- Descripción Larga (El Markdown) -->
        <div class="prose prose-lg text-gray-600 max-w-none mb-12">
          <Content />
        </div>

        <!-- Galería de Imágenes (Si el cliente subió fotos extra) -->
        {propiedad.data.galeria && propiedad.data.galeria.length > 0 && (
          <div class="mb-12">
            <h2 class="text-2xl font-bold text-gray-900 mb-6">Galería</h2>
            <div class="grid grid-cols-2 sm:grid-cols-3 gap-4">
              {propiedad.data.galeria.map((foto) => (
                <img src={foto.imagen} alt="Foto de la propiedad" class="w-full h-40 object-cover rounded-xl shadow-sm hover:opacity-90 transition-opacity cursor-pointer" />
              ))}
            </div>
          </div>
        )}

        <!-- El Mapa Interactivo de Google (Generado con la dirección) -->
        <div class="mb-12">
          <h2 class="text-2xl font-bold text-gray-900 mb-6">Ubicación</h2>
          <div class="w-full h-80 bg-gray-200 rounded-2xl overflow-hidden shadow-inner">
            <iframe 
              width="100%" 
              height="100%" 
              frameborder="0" 
              scrolling="no" 
              marginheight="0" 
              marginwidth="0" 
              src={`https://maps.google.com/maps?q=${encodeURI(propiedad.data.direccion)}&t=&z=15&ie=UTF8&iwloc=&output=embed`}>
            </iframe>
          </div>
        </div>

      </div>

      <!-- COLUMNA DERECHA (Precio y Contacto flotante - 30%) -->
      <div class="lg:w-1/3">
        <!-- El 'sticky' hace que esta tarjeta baje junto con la pantalla cuando haces scroll -->
        <div class="bg-white border border-gray-200 rounded-3xl p-8 shadow-xl sticky top-28">
          <p class="text-sm text-gray-500 font-bold uppercase tracking-wider mb-2">Precio de {propiedad.data.operacion}</p>
          <p class="text-4xl font-bold text-blue-600 mb-6">
            {propiedad.data.moneda} {propiedad.data.precio.toLocaleString()}
          </p>
          
          <div class="border-t border-gray-100 pt-6 mb-8">
            <p class="text-gray-600 mb-4 text-center">¿Te interesa esta propiedad? Contáctanos ahora para agendar una visita.</p>
          </div>
          
          <!-- Botón de WhatsApp o Contacto -->
          <a href="#" class="block w-full bg-gray-900 hover:bg-black text-white text-center font-bold py-4 rounded-xl transition-colors shadow-md text-lg">
            Contactar Agente
          </a>
        </div>
      </div>

    </div>
  </div>

</Layout>