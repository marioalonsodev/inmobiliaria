---
// 1. Importaciones
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import Card from '../components/Card.astro';

// 2. Traemos las propiedades de la base de datos
const propiedades = await getCollection('propiedades');
---

<!-- 3. Envolvemos la página en nuestro Molde Maestro -->
<Layout title="Inicio">
  
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    
    <!-- Título y Subtítulo principal (Hero) -->
    <h1 class="text-5xl font-bold text-center text-gray-900 mb-4 tracking-tight">
      Descubre tu lugar ideal
    </h1>
    <p class="text-xl text-center text-gray-500 mb-12">
      Tenemos cientos de propiedades exclusivas esperando por ti.
    </p>

    <!-- Contenedor Cuadrícula (1 columna en celular, 2 en tablet, 3 en PC) -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 mt-12">
      
      <!-- Magia de Astro: Recorremos las propiedades y dibujamos una Card por cada una -->
      {propiedades.map((propiedad) => (
        <Card propiedad={propiedad} />
      ))}

    </div>
    
  </div>

</Layout>